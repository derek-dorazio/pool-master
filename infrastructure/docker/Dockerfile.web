# Dockerfile for web client (Vite React -> nginx)
# Build context: repo root
#   docker build -f infrastructure/docker/Dockerfile.web -t poolmaster-web .

FROM node:20-slim AS builder
WORKDIR /app

COPY package*.json turbo.json tsconfig.base.json ./
COPY clients/web/ clients/web/

RUN npm ci
RUN npx turbo build --filter=@poolmaster/web

FROM nginx:alpine
COPY --from=builder /app/clients/web/dist /usr/share/nginx/html
COPY infrastructure/docker/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
