FROM node:20-slim AS builder
WORKDIR /app
COPY package.json package-lock.json turbo.json tsconfig.base.json ./
COPY packages/shared/ ./packages/shared/
COPY packages/scoring-service/ ./packages/scoring-service/
RUN npm ci --workspace=@poolmaster/shared --workspace=@poolmaster/scoring-service
RUN npx turbo build --filter=@poolmaster/scoring-service

FROM node:20-slim
WORKDIR /app
COPY --from=builder /app/packages/scoring-service/dist ./dist
COPY --from=builder /app/packages/scoring-service/package.json ./
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/packages/shared ./packages/shared
EXPOSE 3002
CMD ["node", "dist/index.js"]
