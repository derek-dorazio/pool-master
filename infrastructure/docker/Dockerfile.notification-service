# Dockerfile for notification-service
# Build context: repo root
#   docker build -f infrastructure/docker/Dockerfile.notification-service -t poolmaster-notification-service .

FROM node:20-slim AS builder
WORKDIR /app

COPY package*.json turbo.json tsconfig.base.json ./
COPY packages/shared/ packages/shared/
COPY packages/notification-service/ packages/notification-service/

RUN npm ci
RUN npx turbo build --filter=@poolmaster/notification-service

FROM node:20-slim
WORKDIR /app
ENV NODE_ENV=production

COPY --from=builder /app/packages/notification-service/dist ./dist
COPY --from=builder /app/packages/notification-service/package.json ./
COPY --from=builder /app/node_modules ./node_modules

EXPOSE 3004
CMD ["node", "dist/index.js"]
