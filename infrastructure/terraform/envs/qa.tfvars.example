# QA environment — auto-deployed on every push to main
# Copy to qa.tfvars and set db_password: cp qa.tfvars.example qa.tfvars
environment = "qa"
region      = "us-east-2"

# Database
db_instance_class    = "db.t3.micro"
db_allocated_storage = 20
db_password          = "CHANGE_ME_qa_password"

# ECS
ecs_cpu    = 256
ecs_memory = 512
core_api_bootstrap_image_tag = "bootstrap"

# Domain → qa-ultimateofficepoolmanager.com
domain_name         = "ultimateofficepoolmanager.com"
acm_certificate_arn = "arn:aws:acm:us-east-2:614049083306:certificate/4d0fbf35-523d-4e71-bb33-3086aae9e4c8"
route53_zone_id     = "Z020704038X1AEGE6QNM9"
