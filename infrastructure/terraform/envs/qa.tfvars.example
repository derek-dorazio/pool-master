# QA environment — auto-deployed on every push to main
environment = "qa"
region      = "us-east-2"

# Database (smaller for QA)
db_instance_class    = "db.t3.micro"
db_allocated_storage = 20
db_password          = "CHANGE_ME_qa_password"

# ECS (minimal for QA)
ecs_cpu    = 256
ecs_memory = 512

# Domain (uncomment when DNS is configured)
# domain_name         = "yourdomain.com"
# acm_certificate_arn = "arn:aws:acm:us-east-2:614049083306:certificate/your-cert-id"
# route53_zone_id     = "your-zone-id"
