# QA environment — auto-deployed on every push to main
# Copy to qa.tfvars and set db_password: cp qa.tfvars.example qa.tfvars
environment = "qa"
region      = "us-east-2"

# Database
db_instance_class    = "db.t3.micro"
db_allocated_storage = 20
db_password          = "CHANGE_ME_qa_password"
db_publicly_accessible = true
db_allowed_cidr_blocks = ["YOUR_PUBLIC_IP/32"]

# ECS
ecs_cpu    = 256
ecs_memory = 512
core_api_log_level = "debug"
mock_contest_feed_provider_log_level = "debug"
core_api_bootstrap_image_tag = "bootstrap"
mock_contest_feed_provider_bootstrap_image_tag = "bootstrap"

# Sports data providers
sport_data_default_provider = "mock-contest-feed"
sport_data_provider_bindings_json = <<-EOT
{
  "providers": {
    "mock-contest-feed": {
      "baseUrl": "http://mock-contest-feed-provider.qa.poolmaster.internal:3105"
    }
  }
}
EOT

# Domain → qa-ultimateofficepoolmanager.com
domain_name         = "ultimateofficepoolmanager.com"
acm_certificate_arn = "arn:aws:acm:us-east-2:614049083306:certificate/4d0fbf35-523d-4e71-bb33-3086aae9e4c8"
route53_zone_id     = "Z020704038X1AEGE6QNM9"
