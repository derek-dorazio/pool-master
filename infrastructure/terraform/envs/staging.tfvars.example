# Staging environment — deployed manually or on release branch
# Copy to staging.tfvars and set db_password: cp staging.tfvars.example staging.tfvars
environment = "staging"
region      = "us-east-2"

# Database
db_instance_class    = "db.t3.micro"
db_allocated_storage = 20
db_password          = "CHANGE_ME_staging_password"

# ECS
ecs_cpu    = 256
ecs_memory = 512

# Domain → stage-ultimateofficepoolmanager.com
domain_name         = "ultimateofficepoolmanager.com"
acm_certificate_arn = "arn:aws:acm:us-east-2:614049083306:certificate/4d0fbf35-523d-4e71-bb33-3086aae9e4c8"
route53_zone_id     = "Z020704038X1AEGE6QNM9"
