# Staging environment — deployed manually or on release branch
environment = "staging"
region      = "us-east-2"

# Database
db_instance_class    = "db.t3.micro"
db_allocated_storage = 20
db_password          = "CHANGE_ME_staging_password"

# ECS
ecs_cpu    = 256
ecs_memory = 512

# Domain — results in: stage-ultimateofficepoolmanager.com
# domain_name         = "ultimateofficepoolmanager.com"
# acm_certificate_arn = "arn:aws:acm:us-east-2:614049083306:certificate/FILL_IN"
# route53_zone_id     = "FILL_IN"
