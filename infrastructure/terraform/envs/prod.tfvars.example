# Production environment — deployed manually with approval
# Copy to prod.tfvars and set db_password: cp prod.tfvars.example prod.tfvars
environment = "prod"
region      = "us-east-2"

# Database (larger for prod, multi-AZ automatic via environment check in main.tf)
db_instance_class    = "db.t3.small"
db_allocated_storage = 50
db_password          = "CHANGE_ME_strong_prod_password"

# ECS (more resources for prod)
ecs_cpu    = 512
ecs_memory = 1024

# Domain → ultimateofficepoolmanager.com (no prefix for prod)
domain_name         = "ultimateofficepoolmanager.com"
acm_certificate_arn = "arn:aws:acm:us-east-2:614049083306:certificate/4d0fbf35-523d-4e71-bb33-3086aae9e4c8"
route53_zone_id     = "Z020704038X1AEGE6QNM9"
