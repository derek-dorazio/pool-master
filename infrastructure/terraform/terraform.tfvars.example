# PoolMaster — Terraform Variables
# Copy to terraform.tfvars and fill in values:
#   cp terraform.tfvars.example terraform.tfvars
#
# NEVER commit terraform.tfvars (it's in .gitignore)

environment = "dev"
region      = "us-east-2"

# Database
db_password = "CHANGE_ME_use_a_strong_password"

# Domain & SSL (leave empty to skip HTTPS/DNS — deploy with just ALB DNS)
# domain_name         = "poolmaster.app"
# acm_certificate_arn = "arn:aws:acm:us-east-2:614049083306:certificate/your-cert-id"
# route53_zone_id     = "Z0ABC123DEF456"
