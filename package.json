{
  "name": "poolmaster",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tenant fantasy sports pool management platform",
  "workspaces": [
    "packages/*",
    "clients/*"
  ],
  "scripts": {
    "build": "turbo run build --filter=@poolmaster/shared --filter=@poolmaster/core-api --filter=@poolmaster/poolmaster",
    "build:service": "npm run build --workspace @poolmaster/shared && npm run build --workspace @poolmaster/core-api",
    "build:poolmaster": "npm run build --workspace @poolmaster/shared && npm run build --workspace @poolmaster/poolmaster",
    "dev": "turbo run dev --parallel --filter=@poolmaster/core-api --filter=@poolmaster/poolmaster",
    "dev:start": "./scripts/dev-start.sh",
    "dev:infra": "docker compose -f infrastructure/docker/docker-compose.dev.yml up -d postgres dynamodb mailpit",
    "dev:infra:all": "docker compose -f infrastructure/docker/docker-compose.dev.yml up -d",
    "dev:infra:stop": "docker compose -f infrastructure/docker/docker-compose.dev.yml down",
    "db:migrate": "cd packages/core-api && DATABASE_URL=postgresql://postgres:postgres@localhost:5432/poolmaster npx prisma migrate dev",
    "db:seed": "cd packages/core-api && DATABASE_URL=postgresql://postgres:postgres@localhost:5432/poolmaster npx prisma db seed",
    "db:reset": "cd packages/core-api && DATABASE_URL=postgresql://postgres:postgres@localhost:5432/poolmaster npx prisma migrate reset",
    "db:studio": "cd packages/core-api && DATABASE_URL=postgresql://postgres:postgres@localhost:5432/poolmaster npx prisma studio",
    "lint": "eslint 'packages/*/src/**/*.ts' 'clients/poolmaster/src/**/*.{ts,tsx}' --max-warnings 0",
    "typecheck": "turbo run typecheck --filter=@poolmaster/shared --filter=@poolmaster/core-api --filter=@poolmaster/poolmaster --force",
    "test": "jest --config tests/jest.config.js",
    "test:unit": "jest --config tests/jest.config.js tests/unit",
    "test:integration": "jest --config tests/integration/jest.config.js --forceExit",
    "test:service:unit": "npm run test:unit",
    "test:service:integration": "npm run test:integration",
    "test:service:functional-api": "node scripts/run-service-functional-api.mjs",
    "test:poolmaster:unit": "npm run test --workspace @poolmaster/poolmaster",
    "test:poolmaster:browser-e2e": "npm run test:e2e --workspace @poolmaster/poolmaster",
    "test:poolmaster:browser-e2e:list": "npm run test:e2e:list --workspace @poolmaster/poolmaster",
    "test:coverage:service:unit": "jest --config tests/jest.config.js --coverage --coverageDirectory coverage/service-unit --coverageReporters=json-summary --coverageReporters=json --coverageReporters=lcovonly --coverageReporters=clover --coverageReporters=text-summary --forceExit",
    "test:coverage:service:integration": "jest --config tests/integration/jest.config.js --coverage --coverageDirectory coverage/service-integration --coverageReporters=json-summary --coverageReporters=json --coverageReporters=lcovonly --coverageReporters=clover --coverageReporters=text-summary --forceExit",
    "test:coverage:service:functional-api": "node scripts/run-service-functional-api-coverage.mjs",
    "test:coverage:service:merged": "node scripts/run-backend-coverage.mjs",
    "test:coverage:poolmaster:unit": "npm run test:coverage --workspace @poolmaster/poolmaster",
    "test:functional": "npm run test:service:functional-api",
    "test:functional:coverage": "npm run test:coverage:service:functional-api",
    "test:coverage:backend": "npm run test:coverage:service:merged",
    "test:poolmaster": "npm run test:poolmaster:unit",
    "test:coverage:poolmaster": "npm run test:coverage:poolmaster:unit",
    "test:api": "jest --config tests/jest.config.js tests/api",
    "format": "prettier --write .",
    "api:export": "npm run build --workspace @poolmaster/shared && node --import tsx packages/core-api/scripts/export-openapi.ts",
    "api:generate": "npx @hey-api/openapi-ts -f packages/shared/openapi-ts.config.ts",
    "api:validate": "node --import tsx scripts/validate-openapi-spec.ts",
    "api:refresh": "npm run api:export && npm run api:generate"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@hey-api/client-fetch": "^0.13.1",
    "@hey-api/openapi-ts": "^0.95.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "jest-util": "^29.7.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "v8-to-istanbul": "^9.3.0"
  },
  "packageManager": "npm@11.3.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
