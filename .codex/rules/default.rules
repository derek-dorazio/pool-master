# PoolMaster project workflow command approvals for Codex.
#
# Codex loads project-local rules from .codex/rules/ when this repo is trusted.
# Keep these as narrow workflow prefixes rather than broad shells such as `git *`
# or arbitrary runtimes such as `node *`.

prefix_rule(
    pattern = ["bd", ["create", "update", "note", "query", "set-state", "close", "reopen", "link", "label", "dep", "assign", "priority", "list", "show", "status", "ready", "export", "import"]],
    decision = "allow",
    justification = "PoolMaster Beads workflow tracking commands",
)

prefix_rule(
    pattern = ["bd", "dolt", "push"],
    decision = "allow",
    justification = "PoolMaster Beads sync command",
)

prefix_rule(
    pattern = ["npm", "run", ["rules:check", "rules:check:no-mocked-api", "rules:check:route-discipline", "rules:check:test-traceability", "rules:check:test-disable", "rules:check:unsafe-casts", "rules:check:shared-ui-controls", "rules:check:form-query-mirror", "rules:check:no-duplicate-extract-error-message", "rules:check:pr-riley-marker", "typecheck", "lint", "lint:theme-tokens", "api:check", "api:refresh", "api:validate", "test:poolmaster:unit", "test:service:unit", "test:service:integration", "test:service:functional-api", "test:coverage:service:merged", "build", "build:service", "build:poolmaster"]],
    decision = "allow",
    justification = "PoolMaster package scripts used for validation and generated API freshness",
)

prefix_rule(
    pattern = ["npx", "turbo", "typecheck", "--force"],
    decision = "allow",
    justification = "PoolMaster required typecheck gate",
)

prefix_rule(
    pattern = ["npx", "eslint"],
    decision = "allow",
    justification = "PoolMaster lint gate",
)

prefix_rule(
    pattern = ["npx", "jest", "--config", ["tests/jest.config.js", "tests/integration/jest.config.js"]],
    decision = "allow",
    justification = "PoolMaster Jest unit and integration gates",
)

prefix_rule(
    pattern = ["npx", "prisma", "generate", "--schema=packages/core-api/prisma/schema.prisma"],
    decision = "allow",
    justification = "PoolMaster Prisma client generation",
)

prefix_rule(
    pattern = ["node", ["scripts/check-no-mocked-api.mjs", "scripts/check-route-discipline.mjs", "scripts/check-test-traceability.mjs", "scripts/check-test-disable-discipline.mjs", "scripts/check-unsafe-casts.mjs", "scripts/check-shared-ui-controls.mjs", "scripts/check-form-query-mirror.mjs", "scripts/check-no-duplicate-extract-error-message.mjs", "scripts/check-pr-riley-marker.mjs", "scripts/check-feature-theme-tokens.mjs", "scripts/check-openapi-fresh.mjs", "scripts/get-app-installation-token.mjs", "scripts/run-service-functional-api.mjs", "scripts/run-service-functional-api-coverage.mjs", "scripts/run-backend-coverage.mjs"]],
    decision = "allow",
    justification = "PoolMaster checked Node scripts and test runners",
)

prefix_rule(
    pattern = ["gh", "pr", ["create", "edit", "review", "merge", "view", "list", "checks", "comment", "close", "reopen", "ready"]],
    decision = "allow",
    justification = "PoolMaster PR workflow commands",
)

prefix_rule(
    pattern = ["gh", "run", ["list", "view", "watch", "rerun", "download"]],
    decision = "allow",
    justification = "PoolMaster GitHub Actions inspection and rerun commands",
)

prefix_rule(
    pattern = ["gh", "auth", "status"],
    decision = "allow",
    justification = "GitHub CLI identity checks",
)

prefix_rule(
    pattern = ["gh", "api", ["/installation/repositories", "/app", "graphql"]],
    decision = "allow",
    justification = "GitHub API calls used by PoolMaster review identity checks",
)

prefix_rule(
    pattern = ["gh", "api", "repos/derek-dorazio/pool-master"],
    decision = "allow",
    justification = "GitHub API calls scoped to the PoolMaster repository",
)

prefix_rule(
    pattern = [["./scripts/gh-as-codex.sh", "./scripts/gh-as-claude.sh"], "pr", ["review", "edit", "comment"]],
    decision = "allow",
    justification = "PoolMaster review-bot identity wrappers",
)

prefix_rule(
    pattern = ["git", ["status", "diff", "log", "show", "branch", "worktree", "fetch", "pull", "merge", "rebase", "checkout", "restore", "add", "commit"]],
    decision = "allow",
    justification = "PoolMaster branch, merge, staging, and commit workflow",
)

prefix_rule(
    pattern = ["git", "push", ["origin", "-u"]],
    decision = "allow",
    justification = "PoolMaster branch publishing workflow",
)

prefix_rule(
    pattern = ["git", "reset"],
    decision = "allow",
    justification = "PoolMaster merge-conflict and staging recovery workflow",
)

prefix_rule(
    pattern = ["git", "reset", "--hard"],
    decision = "forbidden",
    justification = "Do not discard local work with git reset --hard through an auto-approval rule",
)
