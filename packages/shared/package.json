{
  "name": "@poolmaster/shared",
  "version": "0.1.0",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/src/index.js"
    },
    "./domain": {
      "types": "./domain/index.ts",
      "default": "./dist/domain/index.js"
    },
    "./domain/*": {
      "types": "./domain/*.ts",
      "default": "./dist/domain/*.js"
    },
    "./db": {
      "types": "./db/index.ts",
      "default": "./dist/db/index.js"
    },
    "./events": {
      "types": "./events/index.ts",
      "default": "./dist/events/index.js"
    },
    "./events/*": {
      "types": "./events/*.ts",
      "default": "./dist/events/*.js"
    },
    "./i18n": {
      "types": "./i18n/index.ts",
      "default": "./dist/i18n/index.js"
    },
    "./api-routes": {
      "types": "./api-routes.ts",
      "default": "./dist/api-routes.js"
    },
    "./dto": {
      "types": "./dto/index.ts",
      "default": "./dist/dto/index.js"
    },
    "./dto/*": {
      "types": "./dto/*.ts",
      "default": "./dist/dto/*.js"
    },
    "./generated": {
      "types": "./generated/api-types.ts",
      "default": "./generated/api-types.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "i18next": "^23.12.0",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
