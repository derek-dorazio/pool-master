{
  "name": "@poolmaster/shared",
  "version": "0.1.0",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.js"
    },
    "./domain": {
      "types": "./domain/index.ts",
      "default": "./domain/index.js"
    },
    "./db": {
      "types": "./db/index.ts",
      "default": "./db/index.js"
    },
    "./events": {
      "types": "./events/index.ts",
      "default": "./events/index.js"
    },
    "./i18n": {
      "types": "./i18n/index.ts",
      "default": "./i18n/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "i18next": "^23.12.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
