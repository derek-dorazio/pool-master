{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": ".",
    "outDir": "dist",
    "lib": ["ES2022", "DOM"]
  },
  "include": [
    "domain/**/*",
    "db/**/*",
    "events/**/*",
    "utils/**/*",
    "src/**/*",
    "i18n/**/*",
    "i18n/locales/**/*.json",
    "api-routes.ts",
    "index.ts",
    "dto/**/*",
    "generated/**/*"
  ]
}
