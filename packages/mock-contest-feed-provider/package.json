{
  "name": "@poolmaster/mock-contest-feed-provider",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "generate:openapi": "node --import tsx scripts/export-openapi.ts",
    "generate:client": "npx @hey-api/openapi-ts -f openapi-ts.config.ts",
    "generate": "npm run generate:openapi && npm run generate:client"
  },
  "dependencies": {
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@hey-api/client-fetch": "^0.13.1",
    "@hey-api/openapi-ts": "^0.95.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
