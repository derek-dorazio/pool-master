}

model ConsentRecord {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  consentType String   @map("consent_type") @db.VarChar(50)
  granted     Boolean
  version     String   @db.VarChar(20)
  minimumAgeThreshold Int?   @map("minimum_age_threshold")
  ageAffirmed Boolean?  @map("age_affirmed")
  ipAddress   String?  @map("ip_address") @db.VarChar(45)
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([userId, consentType])
  @@map("consent_records")
}

// =============================================================================
// Admin & Platform Operations
// =============================================================================

model AdminUser {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique @db.VarChar(255)
  name          String    @db.VarChar(255)
  role          String    @default("VIEWER") @db.VarChar(50)
  permissions   String[]  @default([])
  ssoProviderId String?   @map("sso_provider_id") @db.VarChar(255)
  mfaEnabled    Boolean   @default(false) @map("mfa_enabled")
  mfaSecret     String?   @map("mfa_secret") @db.VarChar(255)
  lastLoginAt   DateTime? @map("last_login_at") @db.Timestamptz
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  auditEntries          AdminAuditEntry[]
  impersonationSessions ImpersonationSession[]
  migrationRuns         MigrationRun[]

  @@map("admin_users")
}

model AdminAuditEntry {
  id             String   @id @default(uuid()) @db.Uuid
  adminUserId    String   @map("admin_user_id") @db.Uuid
  adminUserEmail String   @map("admin_user_email") @db.VarChar(255)
  action         String   @db.VarChar(100)
  resourceType   String   @map("resource_type") @db.VarChar(50)
  resourceId     String   @map("resource_id") @db.VarChar(255)
  description    String
  beforeState    Json?    @map("before_state")
  afterState     Json?    @map("after_state")
  reason         String?
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  adminUser AdminUser @relation(fields: [adminUserId], references: [id])

  @@index([createdAt(sort: Desc)])
  @@index([resourceType, resourceId])
  @@index([adminUserId, createdAt(sort: Desc)])
  @@map("admin_audit_log")
}

model ImpersonationSession {
  id          String    @id @default(uuid()) @db.Uuid
  adminUserId String    @map("admin_user_id") @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  startedAt   DateTime  @default(now()) @map("started_at") @db.Timestamptz
  endedAt     DateTime? @map("ended_at") @db.Timestamptz
  isActive    Boolean   @default(true) @map("is_active")

  adminUser AdminUser @relation(fields: [adminUserId], references: [id])
  tenant    Tenant    @relation(fields: [tenantId], references: [id])

  @@map("impersonation_sessions")
}

model MigrationRun {
  id          String    @id @default(uuid()) @db.Uuid
  migrationId String    @map("migration_id") @db.VarChar(255)
  status      String    @default("RUNNING") @db.VarChar(20)
  options     Json
  progress    Json      @default("{}")
  errors      Json      @default("[]")
  startedAt   DateTime  @default(now()) @map("started_at") @db.Timestamptz
  completedAt DateTime? @map("completed_at") @db.Timestamptz
  startedById String    @map("started_by") @db.Uuid

  startedBy AdminUser @relation(fields: [startedById], references: [id])

  @@index([status])
  @@map("migration_runs")
}

// =============================================================================
// Billing & Entitlements
// =============================================================================

model PlanTier {
  id                   String   @id @default(uuid()) @db.Uuid
  name                 String   @db.VarChar(50)
  slug                 String   @unique @db.VarChar(50)
  displayOrder         Int      @default(0) @map("display_order")
  monthlyPriceCents    Int      @default(0) @map("monthly_price_cents")
  annualPriceCents     Int      @default(0) @map("annual_price_cents")
  trialDays            Int      @default(0) @map("trial_days")
  stripeMonthlyPriceId String?  @map("stripe_monthly_price_id") @db.VarChar(255)
  stripeAnnualPriceId  String?  @map("stripe_annual_price_id") @db.VarChar(255)
  entitlements         Json     @default("{}")
  isPublic             Boolean  @default(true) @map("is_public")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("plan_tiers")
}
