// =============================================================================
// Substrate redesign — pool-master-rop.78 / Phase 4 (rop.78.4)
// =============================================================================

/// Sport category — drives per-category detail table dispatch.
/// One row per category; multiple Sport rows may share the same category
/// (e.g., "PGA Masters" and "Wimbledon" use different category but share
/// the ROSTER pool format via tournamentFormat).
enum PrismaSportCategory {
  GOLF
  BASKETBALL
  FOOTBALL
  F1
  NASCAR
  TENNIS
  SOCCER
}

/// Tournament structural format — drives which contest types are valid
/// pool formats for a given Sport. Composes with category to form the
/// (sport × pool format) compatibility matrix in shared/domain.
enum PrismaTournamentFormat {
  STROKE_PLAY_TOURNAMENT
  KNOCKOUT_BRACKET
  SERIES_PLAYOFF
  ROUND_ROBIN_SEASON
  WEEKLY_GAMES_SEASON
  TIME_TRIAL_RACE
  SEASON_OF_RACES
  GROUP_STAGE_KNOCKOUT
  MATCH_PLAY
}

/// Contest format — the pool format applied to a SportEvent (or set of
/// events via ContestSportEvent). Validity vs. tournamentFormat is
/// enforced by the const map in packages/shared/domain (see plans/117 §9).
/// Replaces the legacy `ContestType.SINGLE_EVENT` enum which was a
/// duration/scope concept that turned out not to be load-bearing —
/// duration is now expressed by the ContestSportEvent M:N join (a
/// contest covers 1 or N events).
enum PrismaContestFormat {
  ROSTER
  BRACKET
  PICKEM_CONFIDENCE
  SURVIVOR
  PREDICT_TOP_N
}

// =============================================================================
// UTC Storage Convention
// =============================================================================
//
// ALL timestamps in this schema are stored as UTC.
//
// - Every DateTime column uses @db.Timestamptz (PostgreSQL `timestamptz`).
// - Application code MUST write UTC values — never local times.
// - Timezone conversion is a **display concern** handled by the client using
//   the user's persisted account timezone or the league default timezone when
//   it exists.
// - Resolution order: user timezone > league timezone.
//
// See plans/14-poolmaster-localisation-i18n.md for the full timezone strategy.
// =============================================================================

// =============================================================================
// Identity
// =============================================================================

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  username     String   @unique @db.VarChar(100)
  passwordHash String?  @map("password_hash")
  firstName    String   @map("first_name") @db.VarChar(100)
  lastName     String   @map("last_name") @db.VarChar(100)
  isActive     Boolean  @default(true) @map("is_active")
  authProvider UserAuthProvider?  @map("auth_provider")
  authId       String?  @map("auth_id")
  isRootAdmin  Boolean  @default(false) @map("is_root_admin")
  timezone     String?  @db.VarChar(50)
  locale       String?  @default("en-US") @db.VarChar(10)
  timeFormat   UserTimeFormat?  @default(TWELVE_HOUR) @map("time_format")
  dateFormat   UserDateFormat?  @default(MDY) @map("date_format")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  memberships         LeagueMembership[]
  createdSquads       Squad[]            @relation("SquadCreatedBy")
  squadMemberships    SquadMembership[]
  invitationsSent     LeagueInvitation[] @relation("InvitedBy")
  invitationsAccepted LeagueInvitation[] @relation("AcceptedBy")
  squadOwnerInvitationsSent     SquadOwnerInvitation[] @relation("SquadOwnerInvitedBy")
  squadOwnerInvitationsAccepted SquadOwnerInvitation[] @relation("SquadOwnerAcceptedBy")
  auditActions        CommissionerAuditLog[] @relation("AuditActor")
  rootAdminAuditEntries AdminAuditEntry[]    @relation("RootAdminAuditActor")
  migrationRunsStarted  MigrationRun[]       @relation("MigrationStartedBy")
  notifications       Notification[]

  refreshTokens       RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique
  sessionId String   @default(uuid()) @map("session_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([sessionId])
  @@map("refresh_tokens")
}

// =============================================================================
// League
// =============================================================================

model League {
  id          String   @id @default(uuid()) @db.Uuid
  leagueCode  String   @unique @map("league_code") @db.VarChar(16)
  name        String
  description String?
  createdBy   String   @map("created_by") @db.Uuid
  isActive    Boolean  @default(true) @map("is_active")
  iconKey     PrismaLeagueIconKey @default(TROPHY) @map("icon_key")
  joinPolicy  PrismaLeagueJoinPolicy @default(COMMISSIONER_ONLY) @map("join_policy")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  memberships      LeagueMembership[]
  squads           Squad[]
  squadMemberships SquadMembership[]
  contests         Contest[]
  invitations      LeagueInvitation[]
  squadOwnerInvitations SquadOwnerInvitation[]
  auditLog         CommissionerAuditLog[]
  actionItems      CommissionerActionItem[]

  @@map("leagues")
}

model LeagueMembership {
  id          String   @id @default(uuid()) @db.Uuid
  leagueId    String   @map("league_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  role        PrismaLeagueRole @default(MEMBER)
  status      PrismaLeagueMembershipStatus @default(ACTIVE)
  joinedAt    DateTime @default(now()) @map("joined_at") @db.Timestamptz
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  league  League         @relation(fields: [leagueId], references: [id])
  user    User           @relation(fields: [userId], references: [id])

  @@index([leagueId, status])
  @@unique([leagueId, userId])
  @@map("league_memberships")
}

model Squad {
  id        String   @id @default(uuid()) @db.Uuid
  leagueId   String   @map("league_id") @db.Uuid
  createdBy String   @map("created_by") @db.Uuid
  name      String
  iconKey   PrismaSquadIconKey @default(CAPTAIN_SMILE_FIELD) @map("icon_key")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  league       League            @relation(fields: [leagueId], references: [id])
  creator      User              @relation("SquadCreatedBy", fields: [createdBy], references: [id])
  memberships  SquadMembership[]
  entries      ContestEntry[]
  ownerInvitations SquadOwnerInvitation[]

  @@index([leagueId, isActive])
  @@map("squads")
}

model SquadMembership {
  id        String   @id @default(uuid()) @db.Uuid
  squadId   String   @map("squad_id") @db.Uuid
  leagueId  String   @map("league_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  status    PrismaSquadMembershipStatus @default(ACTIVE)
  joinedAt  DateTime @default(now()) @map("joined_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  squad  Squad  @relation(fields: [squadId], references: [id])
  league League @relation(fields: [leagueId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([squadId, userId])
  @@unique([leagueId, userId])
  @@index([squadId, status])
  @@map("squad_memberships")
}

model LeagueInvitation {
  id          String    @id @default(uuid()) @db.Uuid
  leagueId    String    @map("league_id") @db.Uuid
  email       String?   @db.VarChar(255)
  inviteCode  String    @unique @map("invite_code") @db.VarChar(100)
  inviteType  PrismaLeagueInviteType @default(EMAIL) @map("invite_type")
  status      PrismaLeagueInvitationStatus @default(PENDING)
  maxUses     Int       @default(1) @map("max_uses")
  currentUses Int       @default(0) @map("current_uses")
  invitedBy   String    @map("invited_by") @db.Uuid
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz
  acceptedAt  DateTime? @map("accepted_at") @db.Timestamptz
  acceptedBy  String?   @map("accepted_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  league   League @relation(fields: [leagueId], references: [id])
  inviter  User   @relation("InvitedBy", fields: [invitedBy], references: [id])
  acceptor User?  @relation("AcceptedBy", fields: [acceptedBy], references: [id])

  @@index([leagueId, status])
  @@map("league_invitations")
}

model SquadOwnerInvitation {
  id                   String   @id @default(uuid()) @db.Uuid
  leagueId             String   @map("league_id") @db.Uuid
  squadId              String   @map("squad_id") @db.Uuid
  email                String   @db.VarChar(255)
  inviteCode           String   @unique @map("invite_code") @db.VarChar(100)
  status               PrismaSquadOwnerInvitationStatus @default(PENDING)
  invitedBy            String   @map("invited_by") @db.Uuid
  expiresAt            DateTime? @map("expires_at") @db.Timestamptz
  acceptedAt           DateTime? @map("accepted_at") @db.Timestamptz
  acceptedBy           String?  @map("accepted_by") @db.Uuid
  replacementForUserId String?  @map("replacement_for_user_id") @db.Uuid
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz

  league   League @relation(fields: [leagueId], references: [id])
  squad    Squad  @relation(fields: [squadId], references: [id])
  inviter  User   @relation("SquadOwnerInvitedBy", fields: [invitedBy], references: [id])
  acceptor User?  @relation("SquadOwnerAcceptedBy", fields: [acceptedBy], references: [id])

  @@index([leagueId, status])
  @@index([squadId, status])
  @@map("squad_owner_invitations")
}

model CommissionerAuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  leagueId    String   @map("league_id") @db.Uuid
  contestId   String?  @map("contest_id") @db.Uuid
  actorId     String   @map("actor_id") @db.Uuid
  action      String   @db.VarChar(100)
  category    String   @db.VarChar(50)
  description String
  beforeState Json?    @map("before_state")
  afterState  Json?    @map("after_state")
  reason      String?
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  league League @relation(fields: [leagueId], references: [id])
  actor  User   @relation("AuditActor", fields: [actorId], references: [id])

  @@index([leagueId, createdAt(sort: Desc)])
  @@index([contestId, createdAt(sort: Desc)])
  @@map("commissioner_audit_log")
}

model CommissionerActionItem {
  id          String    @id @default(uuid()) @db.Uuid
  leagueId    String    @map("league_id") @db.Uuid
  contestId   String?   @map("contest_id") @db.Uuid
  title       String    @db.VarChar(255)
  description String?
  actionUrl   String?   @map("action_url") @db.VarChar(500)
  resolved    Boolean   @default(false)
  resolvedAt  DateTime? @map("resolved_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  league League @relation(fields: [leagueId], references: [id])

  @@index([leagueId, resolved, createdAt(sort: Desc)])
  @@map("commissioner_action_items")
}

// =============================================================================
// Sport & Participant
// =============================================================================

model Sport {
  id               String   @id @default(uuid()) @db.Uuid
  name             String   @unique
  participantType  PrismaParticipantType @map("participant_type")
  category         PrismaSportCategory   @default(GOLF)
  tournamentFormat PrismaTournamentFormat @default(STROKE_PLAY_TOURNAMENT) @map("tournament_format")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  seasons      Season[]
  participants Participant[]

  @@map("sports")
}

model Season {
  id        String   @id @default(uuid()) @db.Uuid
  sportId   String   @map("sport_id") @db.Uuid
  name      String
  year      Int
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  sport    Sport     @relation(fields: [sportId], references: [id])

  @@map("seasons")
}

model Participant {
  id              String   @id @default(uuid()) @db.Uuid
  sportId         String   @map("sport_id") @db.Uuid
  name            String
  participantType PrismaParticipantType @map("participant_type")
  externalId      String?  @map("external_id")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Enriched profile fields (Plan 05)
  firstName       String?  @map("first_name")
  lastName        String?  @map("last_name")
  shortName       String?  @map("short_name") @db.VarChar(100)
  nationality     String?  @db.VarChar(10)
  position        String?  @db.VarChar(50)
  teamAffiliation String?  @map("team_affiliation")
  status          PrismaParticipantStatus @default(ACTIVE)
  injuryStatus    Json     @default("{\"status\": \"HEALTHY\"}") @map("injury_status")
  photoUrl        String?  @map("photo_url")
  photoLastUpdated DateTime? @map("photo_last_updated") @db.Timestamptz
  externalIds     Json     @default("{}") @map("external_ids")

  sport            Sport                       @relation(fields: [sportId], references: [id])
  providerMappings ParticipantProviderMapping[]
  sportEventParticipants SportEventParticipant[]

  @@index([sportId])
  @@index([sportId, status])
  @@map("participants")
}

model ParticipantProviderMapping {
  id            String   @id @default(uuid()) @db.Uuid
  participantId String   @map("participant_id") @db.Uuid
  providerId    String   @map("provider_id") @db.VarChar(100)
  externalId    String   @map("external_id") @db.VarChar(255)
  confidence    PrismaParticipantMappingConfidence @default(EXACT)
  mappedAt      DateTime @default(now()) @map("mapped_at") @db.Timestamptz
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  participant Participant @relation(fields: [participantId], references: [id])

  @@unique([providerId, externalId])
  @@index([participantId])
  @@map("participant_provider_mappings")
}

// =============================================================================
// Contest
// =============================================================================

model Contest {
  id                        String    @id @default(uuid()) @db.Uuid
  leagueId                  String    @map("league_id") @db.Uuid
  sportEventId              String?   @map("sport_event_id") @db.Uuid
  name                      String
  status                    String    @default("DRAFT")
  contestFormat             PrismaContestFormat @default(ROSTER) @map("contest_format")
  selectionType             String    @map("selection_type")
  scoringEngine             String    @map("scoring_engine")
  isExclusive               Boolean   @default(false) @map("is_exclusive")
  scoringStopsOnElimination Boolean   @default(false) @map("scoring_stops_on_elimination")
  startsAt                  DateTime? @map("starts_at") @db.Timestamptz
  endsAt                    DateTime? @map("ends_at") @db.Timestamptz
  lockAt                    DateTime? @map("lock_at") @db.Timestamptz
  createdAt                 DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                 DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  league          League                  @relation(fields: [leagueId], references: [id])
  sportEvent      SportEvent?             @relation(fields: [sportEventId], references: [id])
  configuration   ContestConfiguration?
  entries         ContestEntry[]
  draftSession    DraftSession?
  contestSportEvents ContestSportEvent[]

  @@index([leagueId])
  @@index([sportEventId])
  @@index([status])
  @@map("contests")
}

/// M:N join between Contest and SportEvent. Golf-tournament and bracket
/// contests have one row (Contest:Event = 1:1; equivalent to the legacy
/// Contest.sportEventId column which stays for backward read paths).
/// NFL weekly pick'em contests have N rows (one per week's games);
/// season-long racing contests have ~22 rows (one per race). See
/// plans/117 §4.2.
model ContestSportEvent {
  id           String   @id @default(uuid()) @db.Uuid
  contestId    String   @map("contest_id") @db.Uuid
  sportEventId String   @map("sport_event_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  contest    Contest    @relation(fields: [contestId], references: [id])
  sportEvent SportEvent @relation(fields: [sportEventId], references: [id])

  @@unique([contestId, sportEventId])
  @@index([contestId])
  @@index([sportEventId])
  @@map("contest_sport_events")
}

model ContestConfiguration {
  id                   String    @id @default(uuid()) @db.Uuid
  contestId            String    @unique @map("contest_id") @db.Uuid
  templateId           String?   @map("template_id") @db.Uuid
  templateVersion      Int?      @map("template_version")
  selectionType        String    @map("selection_type") @db.VarChar(50)
  configMode           String?   @map("config_mode") @db.VarChar(50)
  configJson           Json?     @map("config_json")
  rounds               Int?
  timePerPickSeconds   Int?      @map("time_per_pick_seconds")
  autoPickPolicy       String?   @map("auto_pick_policy") @db.VarChar(50)
  tierConfig           Json?     @map("tier_config")
  budget               Int?
