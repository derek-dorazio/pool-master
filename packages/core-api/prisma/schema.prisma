/// A pick on a contest entry — references a SportEventParticipant.
/// Unified across contest formats: optional period / slot / tier / cost
/// fields disambiguate per-format usage. The `contestFormat` column is
/// denormalized from the parent Contest to enable per-format partial
/// unique indexes (see plans/117 §7.1).
model ContestEntryPick {
  id                      String   @id @default(uuid()) @db.Uuid
  entryId                 String   @map("entry_id") @db.Uuid
  sportEventParticipantId String   @map("sport_event_participant_id") @db.Uuid
  contestFormat           PrismaContestFormat @map("contest_format")
  period                  Int?
  slot                    Int?
  tier                    String?  @db.VarChar(50)
  cost                    Decimal? @db.Decimal(12, 2)
  isAutoPicked            Boolean  @default(false) @map("is_auto_picked")
  draftRound              Int?     @map("draft_round")
  draftPickNumber         Int?     @map("draft_pick_number")
  pickedAt                DateTime @default(now()) @map("picked_at") @db.Timestamptz
  createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt               DateTime @updatedAt @map("updated_at") @db.Timestamptz

  entry                 ContestEntry @relation(fields: [entryId], references: [id])
  sportEventParticipant SportEventParticipant @relation(fields: [sportEventParticipantId], references: [id])
  participantScores     ContestEntryParticipantScore[]
  draftPickHistories    DraftPickHistory[]
  golfRosterContributions ContestEntryPickGolfRosterContribution[]

  @@index([entryId])
  @@map("contest_entry_picks")
}

/// Per-pick per-round golf-roster contribution. The bridge between a
/// ContestEntryPick, a SportEventParticipantGolfRound, and the contest's
/// scoring rules. Replaces the JSON `detailsJson` on
/// ContestEntryParticipantScoreEvent for golf-roster contests.
/// See plans/117 §8.1.
model ContestEntryPickGolfRosterContribution {
  id                 String   @id @default(uuid()) @db.Uuid
  contestEntryPickId String   @map("contest_entry_pick_id") @db.Uuid
  round              Int
  strokes            Int
  scoreToPar         Int      @map("score_to_par")
  contribution       Decimal  @db.Decimal(12, 4)
  contributedAt      DateTime @default(now()) @map("contributed_at") @db.Timestamptz
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz

  pick ContestEntryPick @relation(fields: [contestEntryPickId], references: [id])

  @@unique([contestEntryPickId, round])
  @@index([contestEntryPickId])
  @@map("contest_entry_pick_golf_roster_contributions")
}

model ContestEntryParticipantScore {
  id              String   @id @default(uuid()) @db.Uuid
  entryId         String   @map("entry_id") @db.Uuid
  pickId          String   @map("pick_id") @db.Uuid
