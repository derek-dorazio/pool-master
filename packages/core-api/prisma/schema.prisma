generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// UTC Storage Convention
// =============================================================================
//
// ALL timestamps in this schema are stored as UTC.
//
// - Every DateTime column uses @db.Timestamptz (PostgreSQL `timestamptz`).
// - Application code MUST write UTC values — never local times.
// - Timezone conversion is a **display concern** handled by the client using
//   the user's timezone preference (UserLocalePreference.timezone) or the
//   league/tenant default timezone.
// - Resolution order: user timezone > league timezone > tenant timezone.
//
// See plans/14-poolmaster-localisation-i18n.md for the full timezone strategy.
// =============================================================================

// =============================================================================
// Tenant & Identity
// =============================================================================

model Tenant {
  id              String   @id @default(uuid()) @db.Uuid
  name            String
  slug            String   @unique
  settings        Json     @default("{}")
  defaultLocale   String   @default("en-US") @map("default_locale") @db.VarChar(10)
  defaultTimezone String   @default("America/New_York") @map("default_timezone") @db.VarChar(50)
  defaultCurrency String   @default("USD") @map("default_currency") @db.VarChar(3)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  users   User[]
  leagues League[]
  seasons Season[]

  impersonationSessions ImpersonationSession[]

  @@map("tenants")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String?  @map("password_hash")
  displayName  String   @map("display_name")
  authProvider String?  @map("auth_provider")
  authId       String?  @map("auth_id")
  tenantId     String   @map("tenant_id") @db.Uuid
  timezone     String?  @db.VarChar(50)
  locale       String?  @default("en-US") @db.VarChar(10)
  timeFormat   String?  @default("12H") @map("time_format") @db.VarChar(5)
  dateFormat   String?  @default("MDY") @map("date_format") @db.VarChar(5)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant              Tenant             @relation(fields: [tenantId], references: [id])
  memberships         LeagueMembership[]
  createdSquads       Squad[]            @relation("SquadCreatedBy")
  squadMemberships    SquadMembership[]
  invitationsSent     LeagueInvitation[] @relation("InvitedBy")
  invitationsAccepted LeagueInvitation[] @relation("AcceptedBy")
  auditActions        CommissionerAuditLog[] @relation("AuditActor")
  notifications       Notification[]
  notificationPreference NotificationPreference?
  deviceRegistrations DeviceRegistration[]
  localePreference    UserLocalePreference?

  refreshTokens       RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique
  userId    String   @map("user_id") @db.Uuid
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("refresh_tokens")
}

// =============================================================================
// League
// =============================================================================

model League {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String
  description String?
  createdBy   String   @map("created_by") @db.Uuid
  visibility  String   @default("PRIVATE")
  maxMembers  Int      @default(20) @map("max_members")
  settings    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant      Tenant             @relation(fields: [tenantId], references: [id])
  memberships      LeagueMembership[]
  squads           Squad[]
  squadMemberships SquadMembership[]
  contests         Contest[]
  invitations      LeagueInvitation[]
  auditLog         CommissionerAuditLog[]
  actionItems      CommissionerActionItem[]

  @@map("leagues")
}

model LeagueMembership {
  id          String   @id @default(uuid()) @db.Uuid
  leagueId    String   @map("league_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  role        String   @default("MANAGER")
  permissions Json     @default("[]")
  joinedAt    DateTime @default(now()) @map("joined_at") @db.Timestamptz
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  league  League         @relation(fields: [leagueId], references: [id])
  user    User           @relation(fields: [userId], references: [id])

  @@unique([leagueId, userId])
  @@map("league_memberships")
}

model Squad {
  id        String   @id @default(uuid()) @db.Uuid
  leagueId   String   @map("league_id") @db.Uuid
  createdBy String   @map("created_by") @db.Uuid
  name      String
  iconUrl   String?  @map("icon_url")
  status    String   @default("ACTIVE") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  league       League            @relation(fields: [leagueId], references: [id])
  creator      User              @relation("SquadCreatedBy", fields: [createdBy], references: [id])
  memberships  SquadMembership[]
  entries      ContestEntry[]

  @@index([leagueId, status])
  @@map("squads")
}

model SquadMembership {
  id        String   @id @default(uuid()) @db.Uuid
  squadId   String   @map("squad_id") @db.Uuid
  leagueId  String   @map("league_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  status    String   @default("ACTIVE") @db.VarChar(20)
  joinedAt  DateTime @default(now()) @map("joined_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  squad  Squad  @relation(fields: [squadId], references: [id])
  league League @relation(fields: [leagueId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([squadId, userId])
  @@unique([leagueId, userId])
  @@index([squadId, status])
  @@map("squad_memberships")
}

model LeagueInvitation {
  id          String    @id @default(uuid()) @db.Uuid
  leagueId    String    @map("league_id") @db.Uuid
  email       String?   @db.VarChar(255)
  inviteCode  String    @unique @map("invite_code") @db.VarChar(100)
  inviteType  String    @default("EMAIL") @map("invite_type") @db.VarChar(20)
  status      String    @default("PENDING") @db.VarChar(20)
  maxUses     Int       @default(1) @map("max_uses")
  currentUses Int       @default(0) @map("current_uses")
  invitedBy   String    @map("invited_by") @db.Uuid
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz
  acceptedAt  DateTime? @map("accepted_at") @db.Timestamptz
  acceptedBy  String?   @map("accepted_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  league   League @relation(fields: [leagueId], references: [id])
  inviter  User   @relation("InvitedBy", fields: [invitedBy], references: [id])
  acceptor User?  @relation("AcceptedBy", fields: [acceptedBy], references: [id])

  @@index([leagueId, status])
  @@map("league_invitations")
}

model CommissionerAuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  leagueId    String   @map("league_id") @db.Uuid
  contestId   String?  @map("contest_id") @db.Uuid
  actorId     String   @map("actor_id") @db.Uuid
  action      String   @db.VarChar(100)
  category    String   @db.VarChar(50)
  description String
  beforeState Json?    @map("before_state")
  afterState  Json?    @map("after_state")
  reason      String?
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  league League @relation(fields: [leagueId], references: [id])
  actor  User   @relation("AuditActor", fields: [actorId], references: [id])

  @@index([leagueId, createdAt(sort: Desc)])
  @@index([contestId, createdAt(sort: Desc)])
  @@map("commissioner_audit_log")
}

model CommissionerActionItem {
  id          String    @id @default(uuid()) @db.Uuid
  leagueId    String    @map("league_id") @db.Uuid
  contestId   String?   @map("contest_id") @db.Uuid
  type        String    @db.VarChar(50)
  priority    String    @default("MEDIUM") @db.VarChar(20)
  title       String    @db.VarChar(255)
  description String?
  actionUrl   String?   @map("action_url") @db.VarChar(500)
  resolved    Boolean   @default(false)
  resolvedAt  DateTime? @map("resolved_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  league League @relation(fields: [leagueId], references: [id])

  @@index([leagueId, resolved, priority])
  @@map("commissioner_action_items")
}

// =============================================================================
// Sport & Participant
// =============================================================================

model Sport {
  id              String   @id @default(uuid()) @db.Uuid
  name            String   @unique
  participantType String   @map("participant_type")
  statSchema      Json     @default("{}") @map("stat_schema")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  seasons      Season[]
  participants Participant[]

  @@map("sports")
}

model Season {
  id        String   @id @default(uuid()) @db.Uuid
  sportId   String   @map("sport_id") @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  year      Int
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  sport    Sport     @relation(fields: [sportId], references: [id])
  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  contests Contest[]

  @@map("seasons")
}

model Participant {
  id              String   @id @default(uuid()) @db.Uuid
  sportId         String   @map("sport_id") @db.Uuid
  name            String
  participantType String   @map("participant_type")
  externalId      String?  @map("external_id")
  metadata        Json     @default("{}")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Enriched profile fields (Plan 05)
  firstName       String?  @map("first_name")
  lastName        String?  @map("last_name")
  shortName       String?  @map("short_name") @db.VarChar(100)
  nationality     String?  @db.VarChar(10)
  position        String?  @db.VarChar(50)
  teamAffiliation String?  @map("team_affiliation")
  status          String   @default("ACTIVE") @db.VarChar(20)
  injuryStatus    Json     @default("{\"status\": \"HEALTHY\"}") @map("injury_status")
  photoUrl        String?  @map("photo_url")
  photoLastUpdated DateTime? @map("photo_last_updated") @db.Timestamptz
  externalIds     Json     @default("{}") @map("external_ids")

  sport            Sport                    @relation(fields: [sportId], references: [id])
  contestPicks     ContestPick[]
  draftPicks       DraftPick[]
  seasonRecords    ParticipantSeasonRecord[]
  providerMappings ParticipantProviderMapping[]
  sportEventParticipants SportEventParticipant[]

  @@index([sportId])
  @@index([sportId, status])
  @@map("participants")
}

model ParticipantSeasonRecord {
  id              String   @id @default(uuid()) @db.Uuid
  participantId   String   @map("participant_id") @db.Uuid
  sport           String   @db.VarChar(50)
  season          String   @db.VarChar(20)
  rankings        Json     @default("[]")
  budgetPrice     Int      @default(0) @map("budget_price")
  priceTier       String?  @map("price_tier") @db.VarChar(50)
  priceUpdatedAt  DateTime? @map("price_updated_at") @db.Timestamptz
  eventsEntered   Int      @default(0) @map("events_entered")
  eventsCompleted Int      @default(0) @map("events_completed")
  wins            Int      @default(0)
  top5Finishes    Int      @default(0) @map("top_5_finishes")
  top10Finishes   Int      @default(0) @map("top_10_finishes")
  top25Finishes   Int      @default(0) @map("top_25_finishes")
  seasonStats     Json     @default("{}") @map("season_stats")
  formRating      Decimal  @default(50.0) @map("form_rating") @db.Decimal(5, 2)
  formTrend       String   @default("STABLE") @map("form_trend") @db.VarChar(20)
  lastUpdated     DateTime @default(now()) @map("last_updated") @db.Timestamptz
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  participant Participant @relation(fields: [participantId], references: [id])

  @@unique([participantId, season])
  @@index([sport, season])
  @@index([budgetPrice])
  @@map("participant_season_records")
}

model ParticipantProviderMapping {
  id            String   @id @default(uuid()) @db.Uuid
  participantId String   @map("participant_id") @db.Uuid
  providerId    String   @map("provider_id") @db.VarChar(100)
  externalId    String   @map("external_id") @db.VarChar(255)
  confidence    String   @default("EXACT") @db.VarChar(20)
  mappedAt      DateTime @default(now()) @map("mapped_at") @db.Timestamptz
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  participant Participant @relation(fields: [participantId], references: [id])

  @@unique([providerId, externalId])
  @@index([participantId])
  @@map("participant_provider_mappings")
}

// =============================================================================
// Contest
// =============================================================================

model Contest {
  id                        String    @id @default(uuid()) @db.Uuid
  leagueId                  String    @map("league_id") @db.Uuid
  seasonId                  String?   @map("season_id") @db.Uuid
  sportEventId              String?   @map("sport_event_id") @db.Uuid
  name                      String
  status                    String    @default("DRAFT")
  contestType               String    @map("contest_type")
  selectionType             String    @map("selection_type")
  scoringEngine             String    @map("scoring_engine")
  isExclusive               Boolean   @default(false) @map("is_exclusive")
  scoringStopsOnElimination Boolean   @default(false) @map("scoring_stops_on_elimination")
  scoringRules              Json      @default("{}") @map("scoring_rules")
  payoutConfig              Json      @default("{}") @map("payout_config")
  sport                     String?   @db.VarChar(50)
  isImported                Boolean   @default(false) @map("is_imported")
  importedBy                String?   @map("imported_by") @db.Uuid
  startDate                 DateTime? @map("start_date") @db.Timestamptz
  endDate                   DateTime? @map("end_date") @db.Timestamptz
  startsAt                  DateTime? @map("starts_at") @db.Timestamptz
  endsAt                    DateTime? @map("ends_at") @db.Timestamptz
  lockAt                    DateTime? @map("lock_at") @db.Timestamptz
  createdAt                 DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                 DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  league          League                  @relation(fields: [leagueId], references: [id])
  season          Season?                 @relation(fields: [seasonId], references: [id])
  sportEvent      SportEvent?             @relation(fields: [sportEventId], references: [id])
  configuration   ContestConfiguration?
  selectionConfig SelectionConfig?
  entries         ContestEntry[]
  picks           ContestPick[]
  brackets        BracketPrediction[]
  draftSession    DraftSession?

  @@index([leagueId])
  @@index([sportEventId])
  @@index([status])
  @@map("contests")
}

model ContestConfiguration {
  id                   String    @id @default(uuid()) @db.Uuid
  contestId            String    @unique @map("contest_id") @db.Uuid
  selectionType        String    @map("selection_type") @db.VarChar(50)
  locksAt              DateTime? @map("locks_at") @db.Timestamptz
  minimumEntries       Int?      @map("minimum_entries")
  maxEntriesPerSquad   Int?      @map("max_entries_per_squad")
  rosterSize           Int?      @map("roster_size")
  totalPrizePoolAmount Float?    @map("total_prize_pool_amount")
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  contest               Contest                        @relation(fields: [contestId], references: [id])
  participantScoringRules ParticipantContestScoringRule[]
  entryAggregationRule  ContestEntryAggregationRule?
  prizeDefinitions      ContestPrizeDefinition[]

  @@map("contest_configurations")
}

model ParticipantContestScoringRule {
  id                             String   @id @default(uuid()) @db.Uuid
  contestConfigurationId         String   @map("contest_configuration_id") @db.Uuid
  participantScoringDefinitionId String   @map("participant_scoring_definition_id") @db.VarChar(100)
  sortOrder                      Int      @map("sort_order")
  config                         Json     @default("{}")
  active                         Boolean  @default(true)
  createdAt                      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  contestConfiguration ContestConfiguration @relation(fields: [contestConfigurationId], references: [id])
  scoreEvents ContestEntryParticipantScoreEvent[]

  @@unique([contestConfigurationId, sortOrder])
  @@index([contestConfigurationId])
  @@map("participant_contest_scoring_rules")
}

model ContestEntryAggregationRule {
  id                      String   @id @default(uuid()) @db.Uuid
  contestConfigurationId  String   @unique @map("contest_configuration_id") @db.Uuid
  aggregationDefinitionId String   @map("aggregation_definition_id") @db.VarChar(100)
  config                  Json     @default("{}")
  active                  Boolean  @default(true)
  createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt               DateTime @updatedAt @map("updated_at") @db.Timestamptz

  contestConfiguration ContestConfiguration @relation(fields: [contestConfigurationId], references: [id])

  @@map("contest_entry_aggregation_rules")
}

model ContestPrizeDefinition {
  id                   String   @id @default(uuid()) @db.Uuid
  contestConfigurationId String @map("contest_configuration_id") @db.Uuid
  prizeDefinitionId    String   @map("prize_definition_id") @db.VarChar(100)
  displayName          String   @map("display_name") @db.VarChar(100)
  sortOrder            Int      @map("sort_order")
  ruleConfig           Json     @default("{}") @map("rule_config")
  payoutType           String?  @map("payout_type") @db.VarChar(50)
  amount               Float?
  percentage           Float?
  active               Boolean  @default(true)
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz

  contestConfiguration ContestConfiguration @relation(fields: [contestConfigurationId], references: [id])
  prizeAwards          ContestEntryPrizeAward[]

  @@unique([contestConfigurationId, sortOrder])
  @@index([contestConfigurationId])
  @@map("contest_prize_definitions")
}

// =============================================================================
// Selection Configuration
// =============================================================================

model SelectionConfig {
  id                       String   @id @default(uuid()) @db.Uuid
  contestId                String   @unique @map("contest_id") @db.Uuid
  selectionType            String   @map("selection_type")

  // Snake Draft
  draftMode                String?  @map("draft_mode")
  rounds                   Int?
  timePerPickSeconds       Int?     @map("time_per_pick_seconds")
  autoPickPolicy           String?  @map("auto_pick_policy")

  // Tiered Pick
  tierConfig               Json?    @map("tier_config")
  tierAssignmentMethod     String?  @map("tier_assignment_method")

  // Budget Pick
  budget                   Int?
  pricingMethod            String?  @map("pricing_method")
  rosterSize               Int?     @map("roster_size")

  // Open Selection
  pickCount                Int?     @map("pick_count")

  // Survivor
  survivorStyle            String?  @map("survivor_style")
  picksPerPeriod           Int?     @map("picks_per_period")
  oneEntityPerSeason       Boolean? @map("one_entity_per_season")
  strikesBeforeElimination Int?     @map("strikes_before_elimination")
  buybacksAllowed          Boolean? @map("buybacks_allowed")

  // Bracket / Pick'em
  roundValues              Json?    @map("round_values")
  startRound               String?  @map("start_round")

  // Shared
  isExclusive              Boolean  @default(false) @map("is_exclusive")
  bestBallN                Int?     @map("best_ball_n")
  missedCutPenalty         Int?     @map("missed_cut_penalty")
  captainSlot              Boolean? @map("captain_slot")
  captainMultiplier        Float?   @map("captain_multiplier")

  createdAt                DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                DateTime @updatedAt @map("updated_at") @db.Timestamptz

  contest Contest @relation(fields: [contestId], references: [id])

  @@map("selection_configs")
}

/// A contest-owned matchup or bracket slot for prediction contests.
model ContestMatchup {
  id                String    @id @default(uuid()) @db.Uuid
  contestId         String    @map("contest_id") @db.Uuid
  eventId           String?   @map("event_id") @db.Uuid
  period            Int
  matchupIndex      Int       @default(1) @map("matchup_index")
  roundNumber       Int?      @map("round_number")
  matchNumber       Int?      @map("match_number")
  label             String?   @db.VarChar(255)
  homeParticipantId String?   @map("home_participant_id") @db.Uuid
  awayParticipantId String?   @map("away_participant_id") @db.Uuid
  startsAt          DateTime? @map("starts_at") @db.Timestamptz
  lockAt            DateTime? @map("lock_at") @db.Timestamptz
  metadata          Json      @default("{}")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([contestId, period, matchupIndex])
  @@index([contestId, period])
  @@index([eventId])
  @@map("contest_matchups")
}

// =============================================================================
// Entry & Picks
// =============================================================================

model ContestEntry {
  id                String   @id @default(uuid()) @db.Uuid
  contestId         String   @map("contest_id") @db.Uuid
  squadId           String   @map("squad_id") @db.Uuid
  entryNumber       Int      @default(1) @map("entry_number")
  name              String
  status            String   @default("ACTIVE") @db.VarChar(20)
  totalScore        Float    @default(0) @map("total_score")
  standingsPosition Int?     @map("standings_position")
  isEliminated      Boolean  @default(false) @map("is_eliminated")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz

  contest Contest @relation(fields: [contestId], references: [id])
  squad   Squad   @relation(fields: [squadId], references: [id])

  rosterPicks RosterPick[]
  contestPicks ContestPick[]
  bracket      BracketPrediction?
  draftPicks   DraftPick[]
  participantScores ContestEntryParticipantScore[]
  prizeAwards ContestEntryPrizeAward[]

  @@unique([contestId, squadId, entryNumber])
  @@index([contestId, standingsPosition])
  @@map("contest_entries")
}

/// A participant picked for a squad selection contest (snake, tiered, budget, open).
model RosterPick {
  id              String   @id @default(uuid()) @db.Uuid
  entryId         String   @map("entry_id") @db.Uuid
  sportEventParticipantId String @map("sport_event_participant_id") @db.Uuid
  draftRound      Int?     @map("draft_round")
