generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Tenant & Identity
// =============================================================================

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  planTier  String   @default("free") @map("plan_tier")
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  users   User[]
  leagues League[]
  seasons Season[]

  @@map("tenants")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  displayName  String   @map("display_name")
  authProvider String?  @map("auth_provider")
  authId       String?  @map("auth_id")
  tenantId     String   @map("tenant_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant              Tenant             @relation(fields: [tenantId], references: [id])
  memberships         LeagueMembership[]
  invitationsSent     LeagueInvitation[] @relation("InvitedBy")
  invitationsAccepted LeagueInvitation[] @relation("AcceptedBy")
  contestTemplates    ContestTemplate[]  @relation("TemplateCreator")
  auditActions        CommissionerAuditLog[] @relation("AuditActor")

  @@map("users")
}

// =============================================================================
// League
// =============================================================================

model League {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String
  description String?
  createdBy   String   @map("created_by") @db.Uuid
  visibility  String   @default("PRIVATE")
  maxMembers  Int      @default(20) @map("max_members")
  settings    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant      Tenant             @relation(fields: [tenantId], references: [id])
  memberships      LeagueMembership[]
  contests         Contest[]
  invitations      LeagueInvitation[]
  auditLog         CommissionerAuditLog[]
  actionItems      CommissionerActionItem[]
  contestTemplates ContestTemplate[]

  @@map("leagues")
}

model LeagueMembership {
  id          String   @id @default(uuid()) @db.Uuid
  leagueId    String   @map("league_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  role        String   @default("MANAGER")
  permissions Json     @default("[]")
  joinedAt    DateTime @default(now()) @map("joined_at") @db.Timestamptz
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  league  League         @relation(fields: [leagueId], references: [id])
  user    User           @relation(fields: [userId], references: [id])
  entries ContestEntry[]

  @@unique([leagueId, userId])
  @@map("league_memberships")
}

model LeagueInvitation {
  id          String    @id @default(uuid()) @db.Uuid
  leagueId    String    @map("league_id") @db.Uuid
  email       String?   @db.VarChar(255)
  inviteCode  String    @unique @map("invite_code") @db.VarChar(100)
  inviteType  String    @default("EMAIL") @map("invite_type") @db.VarChar(20)
  status      String    @default("PENDING") @db.VarChar(20)
  maxUses     Int       @default(1) @map("max_uses")
  currentUses Int       @default(0) @map("current_uses")
  invitedBy   String    @map("invited_by") @db.Uuid
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz
  acceptedAt  DateTime? @map("accepted_at") @db.Timestamptz
  acceptedBy  String?   @map("accepted_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  league   League @relation(fields: [leagueId], references: [id])
  inviter  User   @relation("InvitedBy", fields: [invitedBy], references: [id])
  acceptor User?  @relation("AcceptedBy", fields: [acceptedBy], references: [id])

  @@index([leagueId, status])
  @@map("league_invitations")
}

model CommissionerAuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  leagueId    String   @map("league_id") @db.Uuid
  contestId   String?  @map("contest_id") @db.Uuid
  actorId     String   @map("actor_id") @db.Uuid
  action      String   @db.VarChar(100)
  category    String   @db.VarChar(50)
  description String
  beforeState Json?    @map("before_state")
  afterState  Json?    @map("after_state")
  reason      String?
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  league League @relation(fields: [leagueId], references: [id])
  actor  User   @relation("AuditActor", fields: [actorId], references: [id])

  @@index([leagueId, createdAt(sort: Desc)])
  @@index([contestId, createdAt(sort: Desc)])
  @@map("commissioner_audit_log")
}

model CommissionerActionItem {
  id          String    @id @default(uuid()) @db.Uuid
  leagueId    String    @map("league_id") @db.Uuid
  contestId   String?   @map("contest_id") @db.Uuid
  type        String    @db.VarChar(50)
  priority    String    @default("MEDIUM") @db.VarChar(20)
  title       String    @db.VarChar(255)
  description String?
  actionUrl   String?   @map("action_url") @db.VarChar(500)
  resolved    Boolean   @default(false)
  resolvedAt  DateTime? @map("resolved_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  league League @relation(fields: [leagueId], references: [id])

  @@index([leagueId, resolved, priority])
  @@map("commissioner_action_items")
}

model ContestTemplate {
  id                 String    @id @default(uuid()) @db.Uuid
  leagueId           String    @map("league_id") @db.Uuid
  createdBy          String    @map("created_by") @db.Uuid
  name               String    @db.VarChar(255)
  description        String?
  sport              String    @db.VarChar(50)
  contestType        String    @map("contest_type") @db.VarChar(50)
  draftConfig        Json      @default("{}") @map("draft_config")
  scoringConfig      Json      @default("{}") @map("scoring_config")
  payoutConfig       Json      @default("{}") @map("payout_config")
  poolConfig         Json      @default("{}") @map("pool_config")
  sharedWithTenant   Boolean   @default(false) @map("shared_with_tenant")
  isPlatformTemplate Boolean   @default(false) @map("is_platform_template")
  timesUsed          Int       @default(0) @map("times_used")
  lastUsedAt         DateTime? @map("last_used_at") @db.Timestamptz
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  league  League @relation(fields: [leagueId], references: [id])
  creator User   @relation("TemplateCreator", fields: [createdBy], references: [id])

  @@index([leagueId])
  @@index([isPlatformTemplate])
  @@map("contest_templates")
}

// =============================================================================
// Sport & Participant
// =============================================================================

model Sport {
  id              String   @id @default(uuid()) @db.Uuid
  name            String   @unique
  participantType String   @map("participant_type")
  statSchema      Json     @default("{}") @map("stat_schema")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  seasons      Season[]
  participants Participant[]

  @@map("sports")
}

model Season {
  id        String   @id @default(uuid()) @db.Uuid
  sportId   String   @map("sport_id") @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  year      Int
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  sport    Sport     @relation(fields: [sportId], references: [id])
  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  contests Contest[]

  @@map("seasons")
}

model Participant {
  id              String   @id @default(uuid()) @db.Uuid
  sportId         String   @map("sport_id") @db.Uuid
  name            String
  participantType String   @map("participant_type")
  externalId      String?  @map("external_id")
  metadata        Json     @default("{}")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Enriched profile fields (Plan 05)
  firstName       String?  @map("first_name")
  lastName        String?  @map("last_name")
  shortName       String?  @map("short_name") @db.VarChar(100)
  nationality     String?  @db.VarChar(10)
  position        String?  @db.VarChar(50)
  teamAffiliation String?  @map("team_affiliation")
  status          String   @default("ACTIVE") @db.VarChar(20)
  injuryStatus    Json     @default("{\"status\": \"HEALTHY\"}") @map("injury_status")
  photoUrl        String?  @map("photo_url")
  photoLastUpdated DateTime? @map("photo_last_updated") @db.Timestamptz
  externalIds     Json     @default("{}") @map("external_ids")

  sport            Sport                    @relation(fields: [sportId], references: [id])
  poolEntries      ContestParticipantPool[]
  rosterPicks      RosterPick[]
  contestPicks     ContestPick[]
  draftPicks       DraftPick[]
  seasonRecords    ParticipantSeasonRecord[]
  providerMappings ParticipantProviderMapping[]

  @@index([sportId])
  @@index([sportId, status])
  @@map("participants")
}

model ParticipantSeasonRecord {
  id              String   @id @default(uuid()) @db.Uuid
  participantId   String   @map("participant_id") @db.Uuid
  sport           String   @db.VarChar(50)
  season          String   @db.VarChar(20)
  rankings        Json     @default("[]")
  budgetPrice     Int      @default(0) @map("budget_price")
  priceTier       String?  @map("price_tier") @db.VarChar(50)
  priceUpdatedAt  DateTime? @map("price_updated_at") @db.Timestamptz
  eventsEntered   Int      @default(0) @map("events_entered")
  eventsCompleted Int      @default(0) @map("events_completed")
  wins            Int      @default(0)
  top5Finishes    Int      @default(0) @map("top_5_finishes")
  top10Finishes   Int      @default(0) @map("top_10_finishes")
  top25Finishes   Int      @default(0) @map("top_25_finishes")
  seasonStats     Json     @default("{}") @map("season_stats")
  formRating      Decimal  @default(50.0) @map("form_rating") @db.Decimal(5, 2)
  formTrend       String   @default("STABLE") @map("form_trend") @db.VarChar(20)
  lastUpdated     DateTime @default(now()) @map("last_updated") @db.Timestamptz
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  participant Participant @relation(fields: [participantId], references: [id])

  @@unique([participantId, season])
  @@index([sport, season])
  @@index([budgetPrice])
  @@map("participant_season_records")
}

model ParticipantProviderMapping {
  id            String   @id @default(uuid()) @db.Uuid
  participantId String   @map("participant_id") @db.Uuid
  providerId    String   @map("provider_id") @db.VarChar(100)
  externalId    String   @map("external_id") @db.VarChar(255)
  confidence    String   @default("EXACT") @db.VarChar(20)
  mappedAt      DateTime @default(now()) @map("mapped_at") @db.Timestamptz
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  participant Participant @relation(fields: [participantId], references: [id])

  @@unique([providerId, externalId])
  @@index([participantId])
  @@map("participant_provider_mappings")
}

// =============================================================================
// Contest
// =============================================================================

model Contest {
  id                        String    @id @default(uuid()) @db.Uuid
  leagueId                  String    @map("league_id") @db.Uuid
  seasonId                  String?   @map("season_id") @db.Uuid
  name                      String
  status                    String    @default("DRAFT")
  contestType               String    @map("contest_type")
  selectionType             String    @map("selection_type")
  scoringEngine             String    @map("scoring_engine")
  isExclusive               Boolean   @default(false) @map("is_exclusive")
  scoringStopsOnElimination Boolean   @default(false) @map("scoring_stops_on_elimination")
  scoringRules              Json      @default("{}") @map("scoring_rules")
  payoutConfig              Json      @default("{}") @map("payout_config")
  startsAt                  DateTime? @map("starts_at") @db.Timestamptz
  endsAt                    DateTime? @map("ends_at") @db.Timestamptz
  lockAt                    DateTime? @map("lock_at") @db.Timestamptz
  createdAt                 DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                 DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  league          League                  @relation(fields: [leagueId], references: [id])
  season          Season?                 @relation(fields: [seasonId], references: [id])
  selectionConfig SelectionConfig?
  contestPool     ContestPool?
  pool            ContestParticipantPool[]
  entries         ContestEntry[]
  picks           ContestPick[]
  brackets        BracketPrediction[]
  draftSession    DraftSession?
  standings       ContestStanding[]
  results         ContestResult[]

  @@index([leagueId])
  @@index([status])
  @@map("contests")
}

// =============================================================================
// Selection Configuration
// =============================================================================

model SelectionConfig {
  id                       String   @id @default(uuid()) @db.Uuid
  contestId                String   @unique @map("contest_id") @db.Uuid
  selectionType            String   @map("selection_type")

  // Snake Draft
  draftMode                String?  @map("draft_mode")
  rounds                   Int?
  timePerPickSeconds       Int?     @map("time_per_pick_seconds")
  autoPickPolicy           String?  @map("auto_pick_policy")

  // Tiered Pick
  tierConfig               Json?    @map("tier_config")
  tierAssignmentMethod     String?  @map("tier_assignment_method")

  // Budget Pick
  budget                   Int?
  pricingMethod            String?  @map("pricing_method")
  rosterSize               Int?     @map("roster_size")

  // Open Selection
  pickCount                Int?     @map("pick_count")

  // Survivor
  survivorStyle            String?  @map("survivor_style")
  picksPerPeriod           Int?     @map("picks_per_period")
  oneEntityPerSeason       Boolean? @map("one_entity_per_season")
  strikesBeforeElimination Int?     @map("strikes_before_elimination")
  buybacksAllowed          Boolean? @map("buybacks_allowed")

  // Bracket / Pick'em
  roundValues              Json?    @map("round_values")
  startRound               String?  @map("start_round")

  // Shared
  isExclusive              Boolean  @default(false) @map("is_exclusive")
  bestBallN                Int?     @map("best_ball_n")
  missedCutPenalty         Int?     @map("missed_cut_penalty")
  captainSlot              Boolean? @map("captain_slot")
  captainMultiplier        Float?   @map("captain_multiplier")

  createdAt                DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                DateTime @updatedAt @map("updated_at") @db.Timestamptz

  contest Contest @relation(fields: [contestId], references: [id])

  @@map("selection_configs")
}

// =============================================================================
// Contest Pool (configuration) & Pool Participants (resolved membership)
// =============================================================================

model ContestPool {
  id                     String    @id @default(uuid()) @db.Uuid
  contestId              String    @unique @map("contest_id") @db.Uuid
  sport                  String    @db.VarChar(50)
  eventId                String?   @map("event_id") @db.Uuid
  poolType               String    @map("pool_type") @db.VarChar(50)
  config                 Json      @default("{}")
  excludedParticipantIds String[]  @default([]) @map("excluded_participant_ids") @db.Uuid
  poolLocked             Boolean   @default(false) @map("pool_locked")
  poolLockedAt           DateTime? @map("pool_locked_at") @db.Timestamptz
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  contest      Contest                 @relation(fields: [contestId], references: [id])
  participants ContestParticipantPool[]

  @@map("contest_pools")
}

model ContestParticipantPool {
  id                   String   @id @default(uuid()) @db.Uuid
  poolId               String   @map("pool_id") @db.Uuid
  contestId            String   @map("contest_id") @db.Uuid
  participantId        String   @map("participant_id") @db.Uuid
  cost                 Int?
  tier                 String?
  tierAssignmentMethod String?  @map("tier_assignment_method")
  ranking              Int?
  isAvailable          Boolean  @default(true) @map("is_available")
  unavailableReason    String?  @map("unavailable_reason") @db.VarChar(255)
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz

  pool        ContestPool @relation(fields: [poolId], references: [id])
  contest     Contest     @relation(fields: [contestId], references: [id])
  participant Participant @relation(fields: [participantId], references: [id])

  @@unique([contestId, participantId])
  @@index([contestId])
  @@index([poolId, tier])
  @@map("contest_participant_pool")
}

// =============================================================================
// Entry & Picks
// =============================================================================

model ContestEntry {
  id                 String   @id @default(uuid()) @db.Uuid
  contestId          String   @map("contest_id") @db.Uuid
  leagueMembershipId String   @map("league_membership_id") @db.Uuid
  name               String
  totalScore         Float    @default(0) @map("total_score")
  rank               Int?
  isEliminated       Boolean  @default(false) @map("is_eliminated")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz

  contest    Contest          @relation(fields: [contestId], references: [id])
  membership LeagueMembership @relation(fields: [leagueMembershipId], references: [id])

  rosterPicks RosterPick[]
  contestPicks ContestPick[]
  bracket      BracketPrediction?
  draftPicks   DraftPick[]

  @@unique([contestId, leagueMembershipId])
  @@index([contestId])
  @@map("contest_entries")
}

/// A participant picked for a squad selection contest (snake, tiered, budget, open).
model RosterPick {
  id              String   @id @default(uuid()) @db.Uuid
  entryId         String   @map("entry_id") @db.Uuid
  participantId   String   @map("participant_id") @db.Uuid
  draftRound      Int?     @map("draft_round")
  draftPickNumber Int?     @map("draft_pick_number")
  pickedAt        DateTime @default(now()) @map("picked_at") @db.Timestamptz
  autoPicked      Boolean  @default(false) @map("auto_picked")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  entry       ContestEntry @relation(fields: [entryId], references: [id])
  participant Participant  @relation(fields: [participantId], references: [id])

  @@index([entryId])
  @@map("roster_picks")
}

/// A single pick in a survivor or pick'em contest — one per entry per period.
model ContestPick {
  id               String    @id @default(uuid()) @db.Uuid
  entryId          String    @map("entry_id") @db.Uuid
  contestId        String    @map("contest_id") @db.Uuid
  participantId    String    @map("participant_id") @db.Uuid
  period           Int
  periodLabel      String?   @map("period_label")
  pickedAt         DateTime  @default(now()) @map("picked_at") @db.Timestamptz
  isCorrect        Boolean?  @map("is_correct")
  confidenceWeight Int?      @map("confidence_weight")
  multiplier       Float?
  isReplacement    Boolean   @default(false) @map("is_replacement")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  entry       ContestEntry @relation(fields: [entryId], references: [id])
  contest     Contest      @relation(fields: [contestId], references: [id])
  participant Participant  @relation(fields: [participantId], references: [id])

  @@unique([entryId, contestId, period])
  @@index([contestId, period])
  @@map("contest_picks")
}

/// All bracket predictions submitted at once for a bracket pick'em contest.
model BracketPrediction {
  id              String   @id @default(uuid()) @db.Uuid
  entryId         String   @unique @map("entry_id") @db.Uuid
  contestId       String   @map("contest_id") @db.Uuid
  predictions     Json     @default("[]")
  submittedAt     DateTime @default(now()) @map("submitted_at") @db.Timestamptz
  tiebreakerValue Int?     @map("tiebreaker_value")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  entry   ContestEntry @relation(fields: [entryId], references: [id])
  contest Contest      @relation(fields: [contestId], references: [id])

  @@index([contestId])
  @@map("bracket_predictions")
}

// =============================================================================
// Draft Session (Snake Draft only)
// =============================================================================

model DraftSession {
  id                String    @id @default(uuid()) @db.Uuid
  contestId         String    @unique @map("contest_id") @db.Uuid
  status            String    @default("PENDING")
  currentPickNumber Int       @default(0) @map("current_pick_number")
  currentEntryId    String?   @map("current_entry_id") @db.Uuid
  startedAt         DateTime? @map("started_at") @db.Timestamptz
  pickDeadline      DateTime? @map("pick_deadline") @db.Timestamptz
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  contest Contest     @relation(fields: [contestId], references: [id])
  picks   DraftPick[]

  @@map("draft_sessions")
}

model DraftPick {
  id             String   @id @default(uuid()) @db.Uuid
  draftSessionId String   @map("draft_session_id") @db.Uuid
  entryId        String   @map("entry_id") @db.Uuid
  participantId  String   @map("participant_id") @db.Uuid
  pickNumber     Int      @map("pick_number")
  round          Int
  pickInRound    Int      @map("pick_in_round")
  pickedAt       DateTime @default(now()) @map("picked_at") @db.Timestamptz
  autoPicked     Boolean  @default(false) @map("auto_picked")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  session     DraftSession @relation(fields: [draftSessionId], references: [id])
  entry       ContestEntry @relation(fields: [entryId], references: [id])
  participant Participant  @relation(fields: [participantId], references: [id])

  @@unique([draftSessionId, pickNumber])
  @@index([draftSessionId])
  @@map("draft_picks")
}

// =============================================================================
// Standings & Results
// =============================================================================

model ContestStanding {
  id            String   @id @default(uuid()) @db.Uuid
  contestId     String   @map("contest_id") @db.Uuid
  entryId       String   @map("entry_id") @db.Uuid
  rank          Int
  totalScore    Float    @map("total_score")
  lastUpdatedAt DateTime @map("last_updated_at") @db.Timestamptz
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  contest Contest @relation(fields: [contestId], references: [id])

  @@unique([contestId, entryId])
  @@index([contestId, rank])
  @@map("contest_standings")
}

model ContestResult {
  id          String   @id @default(uuid()) @db.Uuid
  contestId   String   @map("contest_id") @db.Uuid
  entryId     String   @map("entry_id") @db.Uuid
  finalRank   Int      @map("final_rank")
  totalScore  Float    @map("total_score")
  prizeAmount Int?     @map("prize_amount")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  contest Contest @relation(fields: [contestId], references: [id])

  @@unique([contestId, entryId])
  @@index([contestId, finalRank])
  @@map("contest_results")
}
