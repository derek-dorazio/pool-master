{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "..",
    "outDir": "../dist-tests",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "baseUrl": "..",
    "paths": {
      "@poolmaster/shared/*": ["packages/shared/*"],
      "@poolmaster/mock-contest-feed-provider/generated/hey-api/types": [
        "packages/mock-contest-feed-provider/generated/hey-api/types.gen.ts"
      ]
    }
  },
  "include": [
    "./**/*.ts",
    "../packages/*/src/**/*.ts",
    "../packages/shared/**/*.ts"
  ]
}
